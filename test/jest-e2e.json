{
  "moduleFileExtensions": ["js", "json", "ts", "tsx"],
  "testEnvironment": "node",
  "rootDir": ".",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)sx?$": "ts-jest"
  },
  "moduleNameMapper": {
    "^expo-server-sdk$": "<rootDir>/__mocks__/expo-server-sdk.ts"
  },
  "globalSetup": "<rootDir>/global-setup.ts",
  "setupFiles": ["<rootDir>/setup-env.ts"]
}
